{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Hooj",
  "version": "0.1.0",
  "identifier": "dev.hooj",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm run dev",
      "cwd": "frontend"
    },
    "beforeBuildCommand": {
      "script": "pnpm run build",
      "cwd": "frontend"
    },
    "devUrl": "http://localhost:1420",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hooj",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
